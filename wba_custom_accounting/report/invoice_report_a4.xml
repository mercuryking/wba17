<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_a4_invoice_report" model="report.paperformat">
        <field name="name">Paperformat A4 Invoice Report</field>
        <field name="default" eval="True"/>
        <field name="format">custom</field>
        <field name="orientation">Portrait</field>
        <field name="page_height">297</field>
        <field name="page_width">210</field>
        <field name="margin_top">30</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">25</field> 
        <field name="dpi">90</field>
    </record>

    <record id="report_invoice_new" model="ir.actions.report">
        <field name="name">Invoices / Vendor Bill A4</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">wba_custom_accounting.report_invoice_report</field>
        <field name="report_file">wba_custom_accounting.report_invoice_report</field>
        <field name="paperformat_id" ref="paperformat_a4_invoice_report"/>
        <field name="print_report_name">"'Invoice - %s' % (object.name)"</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_invoice_report">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <div class="header">
                    <div class="row">
                        <div class="col-3" style="text-align:left;">
                            <img t-att-src="image_data_uri(o.company_id.logo)" width="170px" height="110px"/>
                        </div>
                        <div class="col-8">
                            <style>
                                .judul{
                                    font-size: 20px;
                                    font-weight: 900;
                                    text-align: center;
                                }
                                .icon{
                                    color:#3363c1;
                                    padding-right: 5px;
                                    margin-top: 1px;
                                }
                            </style>
                            <div class="alamat row" style="font-size: 14px; text-align: left; padding-top: 10px;">
                                <div class="col-1" style="text-align: right; padding-right: 5px;">
                                    <span class="fa fa-map-marker" style="font-size:25px; color:#3363c1;"/>
                                </div>
                                <div class="col-11">
                                    <span t-esc="o.company_id.street"/>
                                    <span t-if="o.company_id.street and o.company_id.street2">, </span>
                                    <span t-esc="o.company_id.street2"/>
                                    <span t-if="o.company_id.street2 and o.company_id.city">, </span>
                                    <span t-esc="o.company_id.city"/>
                                    <span t-if="o.company_id.city and o.company_id.state_id">, </span>
                                    <span t-esc="o.company_id.state_id.name"/>
                                    <span t-esc="o.company_id.zip"/>
                                </div>
                            </div>
                            <div class="row" style="font-size: 14px; text-align: left; padding-top: 5px;">
                                <div class="col-1" style="text-align: right;">
                                    <span class="fa fa-phone icon" style="font-size:22px;"></span>
                                </div>
                                <div class="col-5">
                                    <span t-esc="o.company_id.mobile"/>
                                </div>
                                <div class="col-1" style="text-align: right;">
                                    <span class="fa fa-envelope icon" style="font-size:20px;"></span>
                                </div>
                                <div class="col-5">
                                    <span t-esc="o.company_id.email"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-1" style="display: flex; margin-top: 15px; align-item:right;vertical-align: right; text-align:right;">
                        </div>
                    </div>
                </div>
                <div class="page">
                    <div style="text-align: center; font-size: 16px; font-weight: 800; margin-top: 10px; margin-bottom: 10px; border-top: 2px solid black; border-bottom: 2px solid black; padding: 5px 0;">
                        <t t-if="o.move_type == 'out_invoice'">
                            INVOICE
                        </t>
                        <t t-elif="o.move_type == 'in_invoice'">
                            VENDOR BILL
                        </t>
                    </div>
                    <div class="row">
                        <style>
                            .detail{
                                font-size: 13px;
                                margin-bottom: 4px;
                            }
                        </style>
                        <div class="col-7">
                            <!-- <div class="detail">
                                Nama Pelanggan: <span t-esc="o.partner_id.name" style="font-weight: 700;"/>
                            </div>
                            <div class="detail">   
                                <div class="detail">
                                    Alamat:
                                </div>
                                <div style="margin-left: 15px; margin-top: -5px; font-weight: 700; width: 90%;">
                                    <span t-esc="o.partner_id.street" />
                                    <span t-if="o.partner_id.street and o.partner_id.street2">, </span>
                                    <span t-esc="o.partner_id.street2" />
                                    <span t-if="o.partner_id.street2 and o.partner_id.city">, </span>
                                    <span t-esc="o.partner_id.city" />
                                    <span t-if="o.partner_id.city and o.partner_id.state_id">, </span>
                                    <span t-esc="o.partner_id.state_id.name" />
                                    <span t-if="o.partner_id.state_id and o.partner_id.zip">, </span>
                                    <span t-esc="o.partner_id.zip" />
                                </div>
                            </div>
                            <div>
                                <div class="detail">
                                    <div class="detail">
                                        Alamat Kirim:
                                    </div>
                                    <div style="margin-left: 15px; margin-top: -5px; font-weight: 700;; width: 90%;">
                                        <span t-esc="o.partner_shipping_id.street" />
                                        <span t-if="o.partner_shipping_id.street and o.partner_shipping_id.street2">, </span>
                                        <span t-esc="o.partner_shipping_id.street2" />
                                        <span t-if="o.partner_shipping_id.street2 and o.partner_shipping_id.city">, </span>
                                        <span t-esc="o.partner_shipping_id.city" />
                                        <span t-if="o.partner_shipping_id.city and o.partner_shipping_id.state_id">, </span>
                                        <span t-esc="o.partner_shipping_id.state_id.name" />
                                        <span t-if="o.partner_shipping_id.state_id and o.partner_shipping_id.zip">, </span>
                                        <span t-esc="o.partner_shipping_id.zip" />
                                    </div>
                                </div>
                            </div> -->
                            <table style="width: 100%; font-size: 13px;" class="table-borderless">
                                <tr>
                                    <td style="text-align: left; width: 22%; ">Nama Pelanggan</td>
                                    <td style="text-align: left; width: 78%;">:</td>
                                </tr>
                                <tr>
                                    <td colspan="2">
                                        <div style="margin-top: -5px; font-weight: 700; width: 90%;">
                                            <span t-esc="o.partner_id.name" />
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="text-align: left; width: 22%;">Alamat</td>
                                    <td style="text-align: left; width: 78%;">:</td>
                                </tr>
                                <tr>
                                    <td colspan="2">
                                        <div style="margin-top: -5px; font-weight: 700; width: 90%;">
                                            <span t-esc="o.partner_id.street" />
                                            <span t-if="o.partner_id.street and o.partner_id.street2">, </span>
                                            <span t-esc="o.partner_id.street2" />
                                            <span t-if="o.partner_id.street2 and o.partner_id.city">, </span>
                                            <span t-esc="o.partner_id.city" />
                                            <span t-if="o.partner_id.city and o.partner_id.state_id">, </span>
                                            <span t-esc="o.partner_id.state_id.name" />
                                            <span t-if="o.partner_id.state_id and o.partner_id.zip">, </span>
                                            <span t-esc="o.partner_id.zip" />
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="text-align: left; width: 22%;">Alamat Kirim</td>
                                    <td style="text-align: left; width: 78%;">:</td>
                                </tr>
                                <tr>
                                    <td colspan="2">
                                        <div style="margin-top: -5px; font-weight: 700; width: 90%;">
                                            <span t-esc="o.partner_shipping_id.street" />
                                            <span t-if="o.partner_shipping_id.street and o.partner_shipping_id.street2">, </span>
                                            <span t-esc="o.partner_shipping_id.street2" />
                                            <span t-if="o.partner_shipping_id.street2 and o.partner_shipping_id.city">, </span>
                                            <span t-esc="o.partner_shipping_id.city" />
                                            <span t-if="o.partner_shipping_id.city and o.partner_shipping_id.state_id">, </span>
                                            <span t-esc="o.partner_shipping_id.state_id.name" />
                                            <span t-if="o.partner_shipping_id.state_id and o.partner_shipping_id.zip">, </span>
                                            <span t-esc="o.partner_shipping_id.zip" />
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-5" >
                            <table style="width: 100%; font-size: 13px;" class="table-borderless">
                                <tr>
                                    <td style="text-align: left; width: 30%;">No. Invoice</td>
                                    <td style="text-align: left; width: 4%;">:</td>
                                    <td style="text-align: left; width: 66%;"><span t-esc="o.name" style="font-weight: 700;"/></td>
                                </tr>
                                <tr>
                                    <td style="text-align: left; width: 30%;">No. SO</td>
                                    <td style="text-align: left; width: 4%;">:</td>
                                    <td style="text-align: left; width: 66%;">
                                        <t t-if="o.line_ids.sale_line_ids.order_id">
                                            <span t-esc="', '.join(o.line_ids.mapped('sale_line_ids.order_id').mapped('name'))" style="font-weight: 700;"/>
                                        </t>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="text-align: left; width: 30%;">No. Surat Jalan</td>
                                    <td style="text-align: left; width: 4%;">:</td>
                                    <td style="text-align: left; width: 66%;">
                                        <t t-if="o.line_ids.sale_line_ids.order_id.picking_ids">
                                            <t t-set="pickings" t-value="o.line_ids.mapped('sale_line_ids.order_id').mapped('picking_ids').filtered(lambda x: x.priority == '0')"/>
                                            <span t-esc="', '.join(pickings.mapped('name'))" style="font-weight: 700;"/>
                                        </t>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="text-align: left; width: 30%;">Tanggal Invoice</td>
                                    <td style="text-align: left; width: 4%;">:</td>
                                    <td style="text-align: left; width: 66%;"><span t-esc="o.delivery_date" style="font-weight: 700;"/></td>
                                </tr>
                                <tr>
                                    <td style="text-align: left; width: 30%;">Payment Terms</td>
                                    <td style="text-align: left; width: 4%;">:</td>
                                    <td style="text-align: left; width: 66%;"><span t-esc="o.invoice_payment_term_id.name" style="font-weight: 700;"/></td>
                                </tr>
                                <tr>
                                    <td style="text-align: left; width: 30%;">Due Date</td>
                                    <td style="text-align: left; width: 4%;">:</td>
                                    <td style="text-align: left; width: 66%;"><span t-esc="o.invoice_date_due" style="font-weight: 700;"/></td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    <div class="detail" style="padding-top: 10px;">
                        <style>
                            .table-atas td{
                                padding: 3px 5px 1px 5px;
                                border-right: 1px solid black;
                            }
                            .table-atas th{
                                padding: 3px 2px 3px 5px; 
                                border-bottom: 1px solid black;
                                border-right: 1px solid black;
                            }
                        </style>
                        <table class="table-atas table-borderless" style="width:100%; padding-top: 15px; border: 1px solid black;">
                            <thead>
                                <tr>
                                    <th style="width: 38%;">Nama Barang</th>
                                    <th style="width: 10%">Qty</th>
                                    <th style="width: 10%">Uom</th>
                                    <th style="width: 16%">Harga Satuan</th>
                                    <th style="width: 10%">Diskon(%)</th>
                                    <th style="width: 16%">Jumlah</th>
                                </tr>
                            </thead>
                            <t t-set="harga_barang" t-value="0"/>
                            <t t-set="total_discount" t-value="0"/>
                            <t t-set="invoice_lines" t-value="o.invoice_line_ids.filtered(lambda l: l.product_id != o.company_id.shipping_product_id)" />
                            <tbody>
                                <t t-foreach="invoice_lines" t-as="line">
                                    <t t-set="total_discount" t-value="total_discount + line.discount * line.quantity * line.price_unit / 100"/>
                                    <t t-set="harga_barang" t-value="line.price_unit * line.quantity"/>
                                    <tr>
                                        <td style="text-align: left;">
                                            <t t-out="line.product_id.name"/>
                                        </td>
                                        <td style="text-align: center;">
                                            <t t-out="line.quantity" t-options="{'widget':'float', 'precision':2}"/>
                                        </td>
                                        <td style="text-align: center;">
                                            <t t-out="line.product_uom_id.name"/>
                                        </td>
                                        <td style="text-align: right;">
                                        <span t-options="{'widget':'float', 'precision':2}" t-esc="line.price_unit"/>
                                        </td>
                                        <td style="text-align: right;">
                                            <t t-options="{'widget':'float', 'precision':2}" t-out="line.discount"/>
                                        </td>
                                        <td style="text-align: right;">
                                            <span t-options="{'widget':'float', 'precision':2}" t-esc="harga_barang"/>
                                        </td>
                                    </tr>
                                </t>
                                <t t-if="len(invoice_lines) &lt; 24">
                                    <t t-set="empty_lines" t-value="24 - len(invoice_lines)"/>
                                    <t t-foreach="range(empty_lines)" t-as="line">
                                        <tr>
                                            <td style="border-right: 1px solid black;"><br /></td>
                                            <td style="border-right: 1px solid black;"><br /></td>
                                            <td style="border-right: 1px solid black;"><br /></td>
                                            <td style="border-right: 1px solid black;"><br /></td>
                                            <td style="border-right: 1px solid black;"><br /></td>
                                            <td style=""><br /></td>
                                        </tr>
                                    </t>
                                </t>
                            </tbody>
                        </table>
                    </div>
                    <div class="bawah">
                        <style>
                            .border-table-wrapper { border: 1px solid black; border-radius: 10px; padding: 5px;}
                        </style>
                        <div class="row" style="padding-top: 5px; page-break-inside: avoid;">
                            <div class="col-8" width="100%;">
                                <div class="terbilang border-table-wrapper" width="100%" style="height: 60px; font-size: 13px;">
                                    <span style="font-weight: 800;">Terbilang</span> : <span t-esc="o._num_2_words(o.amount_total) + ' Rupiah'" style="text-transform: capitalize;"/>
                                </div>
                                <div style="width: 100%; padding-top: 3px; font-size: 13px;">
                                    <div style="min-height: 130px;">
                                        <span style="font-weight: 800;">Keterangan</span> : <span t-field="o.narration"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-4 border-table-wrapper" style="height: 140px; margin-left: 5px;">
                                <style>
                                    .table-borderless th, .table-borderless td {
                                        padding: 3px 2px 3px 3px;
                                        font-size: 13px;
                                    }
                                </style>
                                <table class="table-borderless" style="width:100%;">
                                    <!-- <t t-set="ongkos_kirim" t-value="sum(o.order_line.filtered(lambda l: l.product_id == o.company_id.shipping_product_id).mapped('price_subtotal'))"/>
                                    <t t-set="total_before_ongkos_kirim" t-value="o.amount_untaxed - ongkos_kirim"/> -->
                                    <t t-set="dpp" t-value="0"/>
                                    <t t-set="tax_name" t-value="o.invoice_line_ids and o.invoice_line_ids[0].tax_ids and o.invoice_line_ids[0].tax_ids[0].name or ''"/>

                                    <t t-if="'12%' in tax_name">
                                        <t t-set="dpp" t-value="(o.amount_untaxed - total_discount) * 11 / 12"/>
                                    </t>
                                    <t t-else="">
                                        <t t-set="dpp" t-value="o.amount_untaxed - total_discount"/>
                                    </t>
                                    <tr>
                                        <th style="text-align: right;">Subtotal</th>
                                        <td style="text-align: right;">
                                            <span t-options="{'widget':'float', 'precision':2}" t-esc="o.amount_untaxed"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th style="text-align: right; wdith: 40%;">Diskon</th>
                                        <td style="text-align: right; width: 60%;">
                                            <span t-options="{'widget':'float', 'precision':2}" t-esc="total_discount"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th style="text-align: right;">Dasar Pengenaan Pajak</th>
                                        <td style="text-align: right;"><span t-options="{'widget':'float', 'precision':2}" t-esc="dpp"/></td>
                                    </tr>
                                    <tr>
                                        <th style="text-align: right;">PPN</th>
                                        <td style="text-align: right;"><span t-options="{'widget':'float', 'precision':2}" t-esc="o.amount_tax"/></td>
                                    </tr>
                                    <!-- <tr>
                                        <th style="text-align: right;">Biaya lain</th>
                                        <t t-if="ongkos_kirim">
                                            <td style="text-align: right;">
                                                <span t-options="{'widget':'float', 'precision':0}" t-esc="ongkos_kirim"/>
                                            </td>
                                        </t>
                                        <t t-else="">
                                            <td style="text-align: right;">0</td>
                                        </t>
                                    </tr> -->
                                    <tr>
                                        <th style="text-align: right;">Grand Total</th>
                                        <td style="text-align: right;">
                                            <span t-options="{'widget':'float', 'precision':2}" t-esc="o.amount_total"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="divnote" style="padding-top: 20px; page-break-inside: avoid;">
                        <div class="row">
                            <div class="col-9">
                                <div>
                                    <span style=" font-size: 13px; text-align: left;">
                                        Pay To:
                                    </span>
                                </div>
                                <div>
                                    <span style=" font-size: 13px; text-align: left;">
                                        Bank Name: <t t-esc="o.partner_bank_id.bank_id.name if o.partner_bank_id else ''"/>
                                    </span>
                                </div>
                                <div>
                                    <span style=" font-size: 13px; text-align: left;">
                                        Account Number: <t t-esc="o.partner_bank_id.acc_number if o.partner_bank_id else ''"/>
                                    </span>
                                </div>
                                <div>
                                    <span style=" font-size: 13px; text-align: left;">
                                        Account Name: <t t-esc="o.partner_bank_id.acc_holder_name if o.partner_bank_id else ''"/>
                                    </span>
                                </div>
                            </div>
                            <div class="col-3" style="text-align: center;">
                                <div>
                                    <span style=" font-size: 13px; text-align: center;">
                                        Hormat,
                                    </span>
                                </div>
                                <div style="padding-top: 140px; font-size: 13px;">
                                    
                                </div>
                                <div style="font-size: 12px; text-align: center; padding-top: 3px; font-weight: 700;">
                                    Erwin
                                </div>
                                <div style="font-size: 12px; text-align: center; padding-top: 3px; font-weight: 700;">
                                    PT. Win Berkat Abadi
                                </div>
                            </div>
                            
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

</odoo>
