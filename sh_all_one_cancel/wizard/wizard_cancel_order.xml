<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wizard_cancel_order_view_form" model="ir.ui.view">
        <field name="name">wizard.cancel.order.view.form</field>
        <field name="model">wizard.cancel.order</field>
        <field name="arch" type="xml">
            <form string="">
                <group string="Reason">
                    <field name="reason" colspan="2" nolabel="1" />
                </group>
                <footer>
                    <button name="action_cancel_order" string="Cancel" type="object" class="btn-primary"/>
                    <button string="Discard" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
