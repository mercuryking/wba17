<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="purchase_order_category_action" model="ir.actions.act_window">
        <field name="name">Purchase Category</field>
        <field name="res_model">purchase.order.category</field>
        <field name="view_mode">tree</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Purchase Order Category
            </p>
        </field>
    </record>

    <record id="purchase_order_category_view_tree" model="ir.ui.view">
        <field name="name">purchase.order.category.view.tree</field>
        <field name="model">purchase.order.category</field>
        <field name="arch" type="xml">
            <tree string="" editable="bottom">
                <field name="name" />
                <field name="seqeunce_code" />
            </tree>
        </field>
    </record>

    <menuitem
        id="purchase_order_category_menu"
        action="purchase_order_category_action"
        parent="purchase.menu_purchase_config"
        sequence="50"/>

</odoo>
