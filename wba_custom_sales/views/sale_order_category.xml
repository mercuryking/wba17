<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_category_action" model="ir.actions.act_window">
        <field name="name">Sales Category</field>
        <field name="res_model">sale.order.category</field>
        <field name="view_mode">tree</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Sales Order Category
            </p>
        </field>
    </record>

    <record id="sale_order_category_view_tree" model="ir.ui.view">
        <field name="name">sale.order.category.view.tree</field>
        <field name="model">sale.order.category</field>
        <field name="arch" type="xml">
            <tree string="" editable="bottom">
                <field name="name" />
                <field name="sequence_code"/>
            </tree>
        </field>
    </record>

    <menuitem
        id="sale_order_category_menu"
        action="sale_order_category_action"
        parent="sale.menu_sale_config"
        sequence="80"
    />

</odoo>
