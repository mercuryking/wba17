<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_inherit_sale_order_form" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.trp_custom_sales</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <field name="signed_on" position="before">
                <field name="disetujui_oleh"/>
            </field>

            <field name="payment_term_id" position="after">
                <field name="category_id" invisible="id" required="1"/>
            </field>

            <xpath expr="//button[@name='action_confirm' and not(@id)]"
                position="attributes">
                <attribute name="invisible">state != 'draft' or id == False</attribute>
            </xpath>

            <field name="signed_by" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
        </field>
    </record>
    

</odoo>
