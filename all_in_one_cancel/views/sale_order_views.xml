<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_cancel" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.cancel</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_sh_reset_to_draft" string="Reset &amp; Cancel All" type="object" 
                        invisible="state not in ['sale', 'done']" 
                        groups="base.group_system"
                        confirm="This will cancel the order, pickings and invoices. Proceed?"/>
            </xpath>
        </field>
    </record>
</odoo>
